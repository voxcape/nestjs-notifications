# SMTP (only needed if you add 'mail' to WelcomeNotification.channels())
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=secret
MAIL_FROM=noreply@example.com

# Redis (only needed if you enable queueing or broadcast)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
